        txtBirthday.setText("");
        txtAge.setText("");
        txtNationality.setText("");
        txtContact.setText("");
        txtEmail.setText("");
        txtDepartment.setText("");
        txtPosition.setText("");
		grpGender.clearSelection();
		comboBox.setSelectedIndex(0);
	}

  // main method
	public static void main(String[] args) {
