  // gets the user inputs and save it to the file
	public void record() {
		try {
			String empID = txtEmpID.getText();
			String name = txtFullname.getText();
			String bDte = txtBirthday.getText();
			String age = txtAge.getText();
			String civil = (String) comboBox.getSelectedItem();
			String nationality = txtNationality.getText();

			String gender = "";
			if (rdbtnMale.isSelected()) {
				gender = "Male";
			} else if (rdbtnFemale.isSelected()) {
				gender = "Female";
			}

			String contact = txtContact.getText();
			String email = txtEmail.getText();
			String department = txtDepartment.getText();
			String position = txtPosition.getText();

      // save to file
			FileWriter fw = new FileWriter("employees.txt", true);
			BufferedWriter bw = new BufferedWriter(fw);
			bw.write(empID + "#" + name + "#" + bDte + "#" + age + "#" + civil + "#" + nationality + "#"
					+ gender + "#" + contact + "#" + email + "#" + department + "#" + position + "\n");
			bw.close();

			JOptionPane.showMessageDialog(this, "Data Recorded Successfully!", "Saved to File",
					JOptionPane.PLAIN_MESSAGE);

		} catch (IOException e) {
			JOptionPane.showMessageDialog(this, "Saving Failed!", "Error", JOptionPane.ERROR_MESSAGE);
			System.err.println("ERROR" + e);
		}

		clear(); // clears the user inputs in the TextFields

		refreshTable(); // reloads the table
	}

  // reads the contents in the file and add each record as a new row in the table
	public void refreshTable() {
		model.setRowCount(0);
		try {
			BufferedReader br = new BufferedReader(new FileReader("employees.txt"));
			String line;

			int num = 1;
			while ((line = br.readLine()) != null) {
				String[] data = line.split("#");
				Object[] row = new Object[12];
				row[0] = num;

				for (int x = 0; x < data.length; x++) {
					row[x + 1] = data[x];
				}
				model.addRow(row);
				num++;
			}
			br.close();

		} catch (IOException e) {
			JOptionPane.showMessageDialog(this, "Error loading data.", "Error", JOptionPane.ERROR_MESSAGE);
			System.err.println("ERROR" + e);
		}
	}

  // clears the TextFields
	public static void clear() {
