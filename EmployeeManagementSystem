		txtEmpID = new JTextField();
		add(txtEmpID).setBounds(10, 64, 179, 21);

		JLabel lblFullname = new JLabel("Full Name");
		add(lblFullname).setBounds(10, 96, 86, 14);

		txtFullname = new JTextField();
		add(txtFullname).setBounds(10, 114, 179, 20);

		JLabel lblBirthday = new JLabel("Date of Birth (MM/DD/YYYY)");
		add(lblBirthday).setBounds(10, 145, 180, 14);

		txtBirthday = new JTextField();
		add(txtBirthday).setBounds(10, 163, 179, 20);

